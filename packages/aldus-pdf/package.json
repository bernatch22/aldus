{
  "name": "aldus",
  "version": "0.4.0",
  "description": "Pixel-perfect PDF editing over a PDF real content graph, plus a two-agent LLM (reader + editor). One package: the engine+agent (aldus), the embeddable React editor (aldus/editor), and a ready server (aldus/server). `aldus file.pdf` opens the full visual editor + AI in your browser.",
  "keywords": [
    "pdf",
    "pdf-editor",
    "acroform",
    "form-fill",
    "llm",
    "agent",
    "claude"
  ],
  "license": "MIT",
  "author": "Bernardo Castro",
  "homepage": "https://bernardocastro.dev/aldus",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bernatch22/aldus.git"
  },
  "type": "module",
  "bin": {
    "aldus": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./editor": {
      "import": "./dist/editor-lib/index.js"
    },
    "./editor/styles.css": "./dist/editor-lib/styles.css",
    "./server": "./dist/server.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node build.mjs",
    "prepublishOnly": "node build.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.198",
    "@pdf-lib/fontkit": "^1.1.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "zod": "^4.0.0"
  },
  "optionalDependencies": {
    "express": "^4.21.2",
    "multer": "^2.0.1"
  },
  "devDependencies": {
    "@aldus/agent": "workspace:*",
    "@aldus/core": "workspace:*",
    "esbuild": "^0.25.0",
    "tsup": "^8.3.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
